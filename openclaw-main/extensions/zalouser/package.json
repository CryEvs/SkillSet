{
  "name": "@skillset/zalouser",
  "version": "2026.4.20",
  "description": "SkillSet Zalo Personal Account plugin via native zca-js integration",
  "type": "module",
  "dependencies": {
    "typebox": "1.1.28",
    "zca-js": "2.1.2"
  },
  "devDependencies": {
    "@skillset/plugin-sdk": "workspace:*",
    "skillset": "workspace:*"
  },
  "peerDependencies": {
    "skillset": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "skillset": {
      "optional": true
    }
  },
  "skillset": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalouser",
      "label": "Zalo Personal",
      "selectionLabel": "Zalo (Personal Account)",
      "docsPath": "/channels/zalouser",
      "docsLabel": "zalouser",
      "blurb": "Zalo personal account via QR code login.",
      "aliases": [
        "zlu"
      ],
      "order": 85,
      "quickstartAllowFrom": false,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": false
      }
    },
    "install": {
      "npmSpec": "@skillset/zalouser",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "skillsetVersion": "2026.4.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
