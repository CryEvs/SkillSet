{
  "name": "@skillset/whatsapp",
  "version": "2026.4.20",
  "description": "SkillSet WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "jimp": "^1.6.1",
    "qrcode-terminal": "^0.12.0",
    "typebox": "1.1.28",
    "undici": "8.1.0"
  },
  "devDependencies": {
    "@skillset/plugin-sdk": "workspace:*",
    "skillset": "workspace:*"
  },
  "peerDependencies": {
    "skillset": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "skillset": {
      "optional": true
    }
  },
  "skillset": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "setupFeatures": {
      "legacyStateMigrations": true,
      "legacySessionSurfaces": true
    },
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message",
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyWhatsAppAuth"
      },
      "cliAddOptions": [
        {
          "flags": "--auth-dir <path>",
          "description": "WhatsApp auth directory override"
        }
      ]
    },
    "install": {
      "npmSpec": "@skillset/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "build": {
      "skillsetVersion": "2026.4.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
