      "skillset/plugin-sdk/secret-ref-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/secret-ref-runtime.d.ts"
      ],
      "skillset/plugin-sdk/ssrf-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/ssrf-runtime.d.ts"
      ],
      "@skillset/qa-channel/api.js": ["../../dist/plugin-sdk/extensions/qa-channel/api.d.ts"],
      "@skillset/*.js": ["../../packages/plugin-sdk/dist/extensions/*.d.ts", "../*"],
      "@skillset/*": ["../*"],
      "@skillset/plugin-sdk/*": ["../../dist/plugin-sdk/src/plugin-sdk/*.d.ts"],
      "@skillset/anthropic-vertex/api.js": ["./.boundary-stubs/anthropic-vertex-api.d.ts"],
      "@skillset/ollama/api.js": ["./.boundary-stubs/ollama-api.d.ts"],
      "@skillset/ollama/runtime-api.js": ["./.boundary-stubs/ollama-runtime-api.d.ts"],
      "@skillset/speech-core/runtime-api.js": ["./.boundary-stubs/speech-core-runtime-api.d.ts"]
    }
  },
  "include": ["./*.ts", "./src/**/*.ts"],
  "exclude": [
    "./**/*.test.ts",
    "./dist/**",
    "./node_modules/**",
    "./src/test-support/**",
    "./src/**/*test-helpers.ts",
    "./src/**/*test-harness.ts",
    "./src/**/*test-support.ts"
