{
  "extends": "../tsconfig.package-boundary.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "skillset/extension-api": ["../../src/extensionAPI.ts"],
      "skillset/plugin-sdk": ["../../dist/plugin-sdk/src/plugin-sdk/index.d.ts"],
      "skillset/plugin-sdk/*": ["../../dist/plugin-sdk/src/plugin-sdk/*.d.ts"],
      "skillset/plugin-sdk/account-id": ["../../dist/plugin-sdk/src/plugin-sdk/account-id.d.ts"],
      "skillset/plugin-sdk/channel-entry-contract": [
        "../../dist/plugin-sdk/src/plugin-sdk/channel-entry-contract.d.ts"
      ],
      "skillset/plugin-sdk/browser-maintenance": [
        "../../dist/plugin-sdk/src/plugin-sdk/browser-maintenance.d.ts"
      ],
      "skillset/plugin-sdk/browser-config-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/browser-config-runtime.d.ts"
      ],
      "skillset/plugin-sdk/browser-node-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/browser-node-runtime.d.ts"
      ],
      "skillset/plugin-sdk/browser-setup-tools": [
        "../../dist/plugin-sdk/src/plugin-sdk/browser-setup-tools.d.ts"
      ],
      "skillset/plugin-sdk/browser-security-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/browser-security-runtime.d.ts"
      ],
      "skillset/plugin-sdk/channel-secret-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/channel-secret-runtime.d.ts"
      ],
      "skillset/plugin-sdk/channel-streaming": [
        "../../dist/plugin-sdk/src/plugin-sdk/channel-streaming.d.ts"
      ],
      "skillset/plugin-sdk/cli-runtime": ["../../dist/plugin-sdk/src/plugin-sdk/cli-runtime.d.ts"],
      "skillset/plugin-sdk/error-runtime": [
        "../../dist/plugin-sdk/src/plugin-sdk/error-runtime.d.ts"
      ],
      "skillset/plugin-sdk/provider-catalog-shared": [
        "../../dist/plugin-sdk/src/plugin-sdk/provider-catalog-shared.d.ts"
      ],
      "skillset/plugin-sdk/provider-env-vars": [
        "../../dist/plugin-sdk/src/plugin-sdk/provider-env-vars.d.ts"
      ],
      "skillset/plugin-sdk/provider-entry": [
        "../../dist/plugin-sdk/src/plugin-sdk/provider-entry.d.ts"
      ],
      "skillset/plugin-sdk/provider-web-search-contract": [
        "../../dist/plugin-sdk/src/plugin-sdk/provider-web-search-contract.d.ts"
