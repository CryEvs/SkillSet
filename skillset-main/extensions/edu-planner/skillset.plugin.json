{
  "id": "edu-planner",
  "name": "Edu Planner",
  "description": "Educational planning toolkit with assignments, deadlines, local AI planning, STT, scoring, health scale, pet widget and loyalty wallet.",
  "contracts": {
    "tools": ["edu_planner"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "storePath": { "type": "string" },
      "ollamaBaseUrl": { "type": "string", "default": "http://127.0.0.1:11434" },
      "ollamaModel": { "type": "string", "default": "qwen2.5:14b-instruct" },
      "sttPythonPath": { "type": "string", "default": "python" },
      "sttScriptPath": { "type": "string" },
      "defaultSessionMinutesCap": { "type": "number", "default": 180 }
    }
  }
}
